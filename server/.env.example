# ── Server ─────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── MongoDB Atlas ──────────────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/realestate_bengaluru?retryWrites=true&w=majority

# ── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string_min_32_chars
JWT_EXPIRE=7d

# ── Admin credentials ──────────────────────────────────────────────────────
ADMIN_EMAIL=admin@demohomesv1.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Admin

# ── Cloudinary (image uploads) ─────────────────────────────────────────────
# Get from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── CORS ───────────────────────────────────────────────────────────────────
# Your Netlify frontend URL (no trailing slash)
FRONTEND_URL=https://demohomes-v1.netlify.app
